title :: Rally Annotator v1.5.1
 1. label      @(1,1) 1x1 :: Sport:
 2. dropdown   @(2,1) 2x1 :: [badminton, tennis, table_tennis, pickleball, padel]
 3. button     @(4,1) 1x1 :: Help
 4. button     @(1,2) 1x1 :: Back 5s
 5. button     @(2,2) 1x1 :: Play / Resume
 6. button     @(3,2) 1x1 :: Pause
 7. button     @(4,2) 1x1 :: Fwd 5s
 8. label      @(1,3) 1x1 :: Start (s):
 9. text_input @(2,3) 1x1 :: ""
10. label      @(3,3) 1x1 :: End (s):
11. text_input @(4,3) 1x1 :: ""
12. label      @(1,4) 1x1 :: Next rally #:
13. text_input @(2,4) 1x1 :: "1"
14. label      @(3,4) 1x1 :: Ending reason:
