16. button     @(2,5) 1x1 :: Mark END
17. dropdown   @(3,5) 1x1 :: [unknown, winner, forced_error, unforced_error, service_fault, let, other]
18. button     @(4,5) 1x1 :: Save Rally
19. html       @(1,6) 4x2 :: <runtime html>
20. label      @(1,8) 4x1 :: Recent rallies (select one, then Edit/Delete):
21. list       @(1,9) 4x4 :: <list>
22. button     @(1,13) 1x1 :: Edit selected
23. button     @(2,13) 1x1 :: Delete selected
24. button     @(3,13) 1x1 :: Undo last
25. button     @(4,13) 1x1 :: Refresh
